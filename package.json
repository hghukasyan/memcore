{
  "name": "memcore",
  "version": "1.0.2",
  "description": "Lock-free shared in-memory cache for Node.js workers. POSIX shared memory, N-API native addon. Cross-process, zero external services, ultra-low latency.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node-gyp rebuild && tsc",
    "build:addon": "node-gyp rebuild",
    "build:ts": "tsc",
    "rebuild": "node-gyp rebuild && tsc",
    "clean": "node-gyp clean",
    "install": "node-gyp rebuild",
    "prepublishOnly": "node-gyp rebuild && tsc",
    "test": "node dist/test/stress-test.js --workers 1 --ops 5000",
    "benchmark": "node dist/benchmark/benchmark.js",
    "example": "node dist/examples/cluster.js",
    "stress": "node dist/test/stress-test.js",
    "stress:stability": "node dist/test/stress-test.js --stability --duration 60"
  },
  "keywords": [
    "cache",
    "c-plus-plus",
    "cluster",
    "concurrency",
    "data-processing",
    "high-performance",
    "in-memory",
    "inter-process-communication",
    "ipc",
    "lock-free",
    "low-latency",
    "multithreading",
    "n-api",
    "native-addon",
    "napi",
    "nodejs",
    "performance",
    "performance-engineering",
    "posix",
    "realtime",
    "shared-memory",
    "systems-programming",
    "worker",
    "worker-threads",
    "zero-copy"
  ],
  "author": "memcore contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "os": [
    "linux",
    "darwin"
  ],
  "gypfile": true,
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "src",
    "binding.gyp",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/haykghukasyan/memcore.git"
  },
  "bugs": {
    "url": "https://github.com/haykghukasyan/memcore/issues"
  },
  "homepage": "https://github.com/haykghukasyan/memcore#readme"
}
