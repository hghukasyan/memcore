{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["index.ts", "test/**/*.ts", "examples/**/*.ts", "benchmark/**/*.ts"],
  "exclude": ["node_modules", "dist", "build"]
}
